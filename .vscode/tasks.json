{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Neohive: Dashboard",
      "type": "shell",
      "command": "node",
      "args": ["${workspaceFolder}/agent-bridge/cli.js", "dashboard"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "NEOHIVE_DATA_DIR": "${workspaceFolder}/.neohive" }
      },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
