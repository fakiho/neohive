        "env": { "NEOHIVE_DATA_DIR": "${workspaceFolder}/.neohive" }
      },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "focus": true }
    },
    {
      "label": "Neohive: Templates",
      "type": "shell",
      "command": "node",
