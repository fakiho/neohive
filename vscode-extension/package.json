{
  "name": "neohive",
  "displayName": "Neohive",
  "description": "Monitor and manage Neohive AI agent collaboration from VS Code. Real-time agent liveness, workflow tracking, and quick actions — all in your sidebar.",
  "version": "0.4.1",
  "publisher": "alionix",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://neohive.alionix.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/fakiho/neohive",
    "directory": "vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/fakiho/neohive/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Other"],
  "keywords": ["neohive", "mcp", "ai-agents", "multi-agent", "claude", "gemini", "cursor", "copilot", "collaboration"],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0f0f10",
    "theme": "dark"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "neohive",
          "title": "Neohive",
          "icon": "$(symbol-misc)"
        }
      ]
    },
    "views": {
      "neohive": [
        {
          "id": "neohive-agents",
          "name": "Agents",
          "icon": "$(person)"
        },
        {
          "id": "neohive-workflows",
          "name": "Workflows",
          "icon": "$(history)"
        }
      ]
    },
    "commands": [
      {
        "command": "neohive.refreshAgents",
        "title": "Neohive: Refresh Agents",
        "icon": "$(refresh)"
      },
      {
        "command": "neohive.refreshWorkflows",
        "title": "Neohive: Refresh Workflows",
        "icon": "$(refresh)"
      },
      {
        "command": "neohive.showAgents",
        "title": "Neohive: Show Agents"
      },
      {
        "command": "neohive.showWorkflows",
        "title": "Neohive: Show Workflows"
      },
      {
        "command": "neohive.setupMcp",
        "title": "Neohive: Set Up MCP for Copilot Chat"
      },
      {
        "command": "neohive.setupHooks",
        "title": "Neohive: Set Up Claude Code Hooks"
      },
      {
        "command": "neohive.configureAgentName",
        "title": "Neohive: Configure Agent Name",
        "icon": "$(person)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "neohive.refreshAgents",
          "when": "view == neohive-agents",
          "group": "navigation"
        },
        {
          "command": "neohive.refreshWorkflows",
          "when": "view == neohive-workflows",
          "group": "navigation"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "neohive.coordinator",
        "name": "neohive",
        "description": "Query agent status, tasks, and messages — or pipe requests to the coordinator",
        "isSticky": false,
        "commands": [
          {
            "name": "status",
            "description": "Show online agents and their status"
          },
          {
            "name": "who",
            "description": "List all registered agents and their roles"
          },
          {
            "name": "tasks",
            "description": "List active tasks (pending, in_progress, in_review)"
          },
          {
            "name": "messages",
            "description": "Show the last 10 messages from the team"
          }
        ]
      }
    ],
    "configuration": {
      "title": "Neohive",
      "properties": {
        "neohive.serverUrl": {
          "type": "string",
          "default": "http://localhost:4321",
          "description": "URL of the Neohive HTTP server"
        },
        "neohive.pollInterval": {
          "type": "number",
          "default": 5000,
          "description": "Polling interval in milliseconds for agent/workflow status"
        },
        "neohive.agentName": {
          "type": "string",
          "default": "",
          "description": "Neohive agent name for this workspace (1–20 chars, alphanumeric/_/-). When set, the extension writes .neohive/ide-activity-{name}.json so the server can layer IDE focus/idle on agent status."
        },
        "neohive.devMode": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, MCP setup uses local server.js instead of the published npm package. Also activates when a .neohive-dev file exists in the workspace root."
        }
      }
    }
  }
}
